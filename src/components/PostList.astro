---
import { formatDate, formatMonthDay } from '../lib/date'
import type { PostSummary } from '../types/blog'

interface Props {
  posts: PostSummary[]
  mode?: 'home' | 'archive'
}

const { posts, mode = 'home' } = Astro.props

const postsByYear = posts.reduce<Record<string, PostSummary[]>>((acc, post) => {
  const year = `${post.createdAt.getFullYear()}`
  acc[year] ??= []
  acc[year].push(post)
  return acc
}, {})
---

{
  mode === 'home' && (
    <section>
      <div class="mb-8 text-sm font-medium tracking-[0.05em] text-tertiary">最近文章</div>

      {
        posts.map((post) => (
          <article class="mb-12">
            <a href={post.url} class="group block">
              <div class="mb-3 flex items-center gap-2 font-mono text-[0.86rem] text-tertiary">
                <span class="inline-block h-3 w-[2px] rounded-full bg-brand" />
                {formatDate(post.createdAt)}
              </div>
              <h2 class="mb-3 font-serif text-[clamp(1.8rem,3.8vw,2rem)] leading-[1.2] font-medium text-primary transition-colors group-hover:text-brand">
                {post.title}
              </h2>
              <p class="text-[1.06rem] text-secondary">{post.description}</p>
            </a>
          </article>
        ))
      }

      <div class="mt-12 flex justify-end">
        <a
          class="inline-flex items-center gap-1.5 text-secondary transition-colors hover:text-brand"
          href="/archive/"
        >
          查看全部
          <svg
            class="h-4 w-4 fill-none stroke-current stroke-2"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </section>
  )
}

{
  mode === 'archive' && (
    <section class="grid gap-10">
      {
        Object.entries(postsByYear).map(([year, yearPosts]) => (
          <div>
            <h2 class="mb-4 font-serif text-[1.65rem] font-medium tracking-[0.02em] text-tertiary">{year}</h2>
            <ul class="m-0 grid list-none gap-1 p-0">
              {
                yearPosts.map((post) => (
                  <li>
                    <a
                      href={post.url}
                      class="group -mx-4 flex items-baseline gap-4 rounded-xl px-4 py-3 transition-colors hover:bg-elevated"
                    >
                      <span class="w-[4.5rem] shrink-0 font-mono text-[0.9rem] text-tertiary transition-colors group-hover:text-brand">
                        {formatMonthDay(post.createdAt)}
                      </span>
                      <span class="font-serif text-[1.25rem] leading-[1.3] font-medium text-primary transition-colors group-hover:text-brand">
                        {post.title}
                      </span>
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        ))
      }
    </section>
  )
}
