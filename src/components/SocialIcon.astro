---
import type { SocialIcon } from '../config/constants'

interface Props {
  icon: SocialIcon
  class?: string
}

const { icon, class: className = 'h-[1.1rem] w-[1.1rem] fill-current' } =
  Astro.props
---

{
  icon === 'github' && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true">
      <path
        d="M12 .297a12 12 0 0 0-3.794 23.39c.6.11.82-.26.82-.58 0-.29-.01-1.05-.016-2.06-3.338.73-4.042-1.61-4.042-1.61a3.18 3.18 0 0 0-1.335-1.76c-1.09-.74.083-.72.083-.72a2.51 2.51 0 0 1 1.83 1.23 2.54 2.54 0 0 0 3.47.99 2.55 2.55 0 0 1 .76-1.61c-2.66-.3-5.46-1.33-5.46-5.92a4.63 4.63 0 0 1 1.23-3.22 4.3 4.3 0 0 1 .12-3.17s1-.32 3.29 1.23a11.4 11.4 0 0 1 6 0c2.28-1.55 3.28-1.23 3.28-1.23.65 1.65.24 2.87.12 3.17a4.63 4.63 0 0 1 1.23 3.22c0 4.6-2.81 5.62-5.48 5.92.44.37.82 1.1.82 2.23 0 1.61-.02 2.9-.02 3.29 0 .32.22.7.83.58A12 12 0 0 0 12 .297"
      />
    </svg>
  )
}

{
  icon === 'x' && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true">
      <path d="M18.9 2H22l-6.77 7.74L23 22h-6.1l-4.77-6.24L6.67 22H3.56l7.25-8.3L1 2h6.25l4.32 5.7zM17.83 20h1.7L6.32 3.9h-1.8z" />
    </svg>
  )
}

{
  icon === 'bilibili' && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true">
      <path d="M19.3 6.5h-3.2l1.5-1.5a1 1 0 1 0-1.4-1.4L14 5.8h-4L7.8 3.6A1 1 0 1 0 6.4 5l1.5 1.5H4.7C3.2 6.5 2 7.7 2 9.2v8.1C2 18.8 3.2 20 4.7 20h14.6c1.5 0 2.7-1.2 2.7-2.7V9.2c0-1.5-1.2-2.7-2.7-2.7M8.5 15.8a1.3 1.3 0 1 1 0-2.6 1.3 1.3 0 0 1 0 2.6m7 0a1.3 1.3 0 1 1 0-2.6 1.3 1.3 0 0 1 0 2.6" />
    </svg>
  )
}

{
  icon === 'mail' && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true">
      <path d="M4 5h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2m8 7.5L4 8v9h16V8z" />
    </svg>
  )
}
