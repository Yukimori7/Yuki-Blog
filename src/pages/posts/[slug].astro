---
import { getCollection, render, type CollectionEntry } from 'astro:content'

import SiteFooter from '../../components/SiteFooter.astro'
import SiteHeader from '../../components/SiteHeader.astro'
import { formatDate } from '../../lib/date'
import Layout from '../../layouts/Layout.astro'

interface Props {
  post: CollectionEntry<'blog'>
}

export const getStaticPaths = async () => {
  const posts = await getCollection('blog')

  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/i, '').toLowerCase() },
    props: { post },
  }))
}

const { post } = Astro.props as Props
const { Content } = await render(post)
---

<Layout title={`${post.data.title} | YukiMori's Blog`} description={post.data.description}>
  <SiteHeader currentPath={Astro.url.pathname} />

  <main class="content-enter mb-16 mt-8">
    <h1 class="mb-5 font-serif text-[clamp(1.9rem,5.5vw,3.25rem)] leading-[1.1] font-medium text-primary">
      {post.data.title}
    </h1>

    <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
      <time class="font-mono text-[0.85rem] text-tertiary">{formatDate(post.data.createAt)}</time>
      {
        post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <span class="font-mono text-[0.75rem] tracking-wide text-tertiary">
                #{tag}
              </span>
            ))}
          </div>
        )
      }
    </div>

    <div class="mb-10 mt-6 h-px bg-subtle"></div>

    <article class="prose">
      <Content />
    </article>
  </main>

  <SiteFooter />
</Layout>
